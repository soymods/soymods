{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/pathmind",
      "destination": "/pathmind/",
      "permanent": true
    },
    {
      "source": "/visual-keystrokes",
      "destination": "/visual-keystrokes/",
      "permanent": true
    },
    {
      "source": "/oreveil",
      "destination": "/oreveil/",
      "permanent": true
    },
    {
      "source": "/about",
      "destination": "/about/",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.soymods.com"
        }
      ],
      "destination": "https://soymods.com/$1",
      "permanent": true
    }
  ]
}
